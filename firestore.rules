rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user is the document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Products - anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categories - anyone can read, only admin can write
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Users - users can read/update their own doc (but NOT change role), admin can do anything
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders - users can read/create their own, admin can read/update all
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'customer', 'email', 'phone', 'items', 'total', 'status'])
        && request.resource.data.status == 'pending'
        && request.resource.data.total > 0
        && request.resource.data.items.size() > 0;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings - store settings are public, sensitive settings are admin-only
    match /settings/store {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sensitive settings (CJ API keys, email SMTP, etc.) - admin only
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Contact Messages - anyone authenticated can create, only admin can read/update/delete
    match /contactMessages/{messageId} {
      allow create: if true
        && request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message', 'read'])
        && request.resource.data.read == false
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000;
      allow read, update, delete: if isAdmin();
    }

    // Deny all other documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
